{
  "manifest_version": 3,
  "name": "Simple Todo Extension",
  "version": "1.0.0",
  "description": "A simple todo manager built as a Chrome extension.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Simple Todo",
    "default_popup": "popup.html",
    "default_icon": {"128": "icons/icon128.png"    }
  },
  "background": {
    "service_worker": "background.js"
  }
}